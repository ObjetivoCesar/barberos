generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Barbershop {
  id               String         @id @default(cuid())
  name             String
  whatsappNumber   String         @unique
  evolutionInstance String
  evolutionApiKey  String
  requiredCuts     Int            @default(5)
  googleMapsUrl    String?
  planStatus       String         @default("TRIAL")
  trialEndsAt      DateTime?
  connectionStatus  String             @default("CONNECTED") // Reservado para uso futuro (ej. Evolution API down)
  createdAt         DateTime           @default(now())
  staff             BarberStaff[]
  customers         BarberCustomer[]
  pushSubscriptions PushSubscription[]
  visitAttempts     VisitAttempt[]
}

model MagicToken {
  id           String   @id @default(cuid())
  barbershopId String
  token        String   @unique
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())
}

model BarberStaff {
  id           String    @id @default(cuid())
  barbershopId String
  name         String
  role         String    @default("BARBER")
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}

model BarberCustomer {
  id                     String    @id @default(cuid())
  barbershopId           String
  whatsapp               String
  name                   String?
  cutsCount              Int       @default(0)
  sessionState           String    @default("IDLE")
  sessionAttempts        Int       @default(0) // Contador de intentos de selección de barbero
  lastVisitAt            DateTime?
  lastReactivationSentAt DateTime? // Campo para controlar el cron de reactivación
  barbershop             Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  visits                 BarberVisit[]

  @@unique([barbershopId, whatsapp])
}

model BarberVisit {
  id          String    @id @default(cuid())
  customerId  String
  staffId     String?
  rating      Int?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  rejectedAt  DateTime? // Timestamp cuando fue rechazado
  recoveredAt DateTime? // Timestamp cuando fue recuperado
  createdAt   DateTime  @default(now())
  customer    BarberCustomer @relation(fields: [customerId], references: [id])
}

// Log de intentos de check-in para auditoría anti-spam
model VisitAttempt {
  id           String     @id @default(cuid())
  customerId   String
  barbershopId String
  pushName     String? // Nombre de WhatsApp (para auditoría, NO para nombre real)
  status       String   // ATTEMPTED | BLOCKED_24H | REJECTED | APPROVED
  reason       String? // "24h_limit", "duplicate", "manual_reject", etc.
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model PushSubscription {
  id           String     @id @default(cuid())
  barbershopId String
  endpoint     String     @unique
  p256dh       String
  auth         String
  createdAt    DateTime   @default(now())
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}
